# SDLC Tools — Project Configuration
# Committed to git. Contains project-level settings only.
# User-level settings (token, custom prompt, AI keys) go in ~/.sdlc/config.yml
# (run: sdlc-tools setup)
#
# Config precedence (lowest → highest):
#   code defaults → ~/.sdlc/config.yml → .sdlc.yml → env vars → CLI args
#
# See: https://github.com/White-Yaksha/sdlc-tools
sdlc:
  # Base branch for diff comparison (e.g., develop, main, releases/2026.3).
  # base_branch: develop

  # Prefix that identifies release branches (used by tag automation).
  # release_prefix: releases

  # Maximum characters of diff to send to the AI analysis.
  # max_diff_length: 20000

  # HTML comment marker for idempotent PR comment updates.
  # comment_marker: "<!-- AI-SDLC-REPORT -->"

  # AI provider for code analysis.
  # Options: copilot, openai, anthropic, gemini, ollama
  # ai_provider: copilot

  # Override the default model for the chosen provider.
  # ai_model: gpt-4o

  # Custom API endpoint (for proxies or self-hosted models).
  # ai_base_url: ""

  # Timeout in seconds for AI API calls.
  # ai_timeout: 120
